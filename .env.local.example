# Copy this file to .env.local and fill in your values.
# For Vercel deployments, run `vercel env pull .env.local` after linking a Neon database.

ANTHROPIC_API_KEY=sk-ant-...

# Neon / Vercel Postgres connection string
# Local: create a free Neon project at https://neon.tech and paste the connection string here
# Vercel: injected automatically when you link a Neon database in the Vercel dashboard
DATABASE_URL=postgres://...
# (Vercel also injects POSTGRES_URL — either one works)
